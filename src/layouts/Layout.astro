---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const {
  title,
  description = 'Thomas McGovern CPA — Author of Road to the Final Hour on the future of college sports.',
  ogImage = 'https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png',
} = Astro.props;
const currentYear = new Date().getFullYear();
const canonicalURL = new URL(Astro.url.pathname, 'https://thomasmcgovern.cpa');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/png" href="https://cdn.sanity.io/images/fkqsnbt5/production/33635bf052499f6d535f3f97a375d46cae8e894b-192x192.png" />
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/archivo/archivo-300.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/archivo/archivo-400.woff2" crossorigin />

    <!-- Below-fold CSS loaded async (non-render-blocking) -->
    <link rel="preload" as="style" href="/deferred.css" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="/deferred.css" /></noscript>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- JSON-LD Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Thomas A. McGovern",
      "url": "https://thomasmcgovern.cpa",
      "jobTitle": "CPA, CFA",
      "description": "Author of Road to the Final Hour",
      "sameAs": [
        "https://x.com/thomasmcgovern",
        "https://www.facebook.com/profile.php?id=thomasmcgovern",
        "https://www.instagram.com/thomasmcgovern"
      ]
    })}></script>

    <slot name="head" />
  </head>
  <body>
    <!-- HEADER — entire header overlays the hero via negative margin -->
