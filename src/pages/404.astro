---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---
<Layout title="Page Not Found — Thomas McGovern CPA">
  <Fragment slot="head"><meta name="robots" content="noindex, nofollow" /></Fragment>
  <main class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <p class="eyebrow mb-3">Error 404</p>
    <h1 class="heading-section mb-4">Page Not Found</h1>
    <p class="text-body mb-8 text-gray-600">The page you are looking for does not exist or has been moved.</p>
    <a href="/" class="inline-block px-8 py-3 bg-primary text-white font-bold uppercase rounded-lg hover:bg-primary-dark transition-colors" style="font-family: var(--font-narrow);">Go Home</a>
  </main>
</Layout>
