---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { sanityClient, urlFor } from '../../lib/sanity.ts';

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "blogPost"] { "slug": slug.current }`);
  return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

const post = await sanityClient.fetch(`*[_type == "blogPost" && slug.current == $slug][0]`, { slug });

if (!post) {
  return Astro.redirect('/blogs');
}

function renderPortableText(blocks: any[]): string {
  if (!Array.isArray(blocks)) return '';
  return blocks
    .map((block: any) => {
      if (!block || block._type !== 'block') return '';
      const children = Array.isArray(block.children) ? block.children : [];
      const textContent = children
        .map((child: any) => {
          if (!child) return '';
          let text = child.text || '';
          const marks = Array.isArray(child.marks) ? child.marks : [];
          if (marks.includes('strong')) text = `<strong>${text}</strong>`;
          if (marks.includes('em')) text = `<em>${text}</em>`;
          return text;
        })
        .join('');
      const style = block.style || 'normal';
      if (style === 'h2') return `<h2 class="heading-sub mt-12 mb-4">${textContent}</h2>`;
      if (style === 'h3') return `<h3 class="heading-sub-sm mt-8 mb-3">${textContent}</h3>`;
      return `<p class="text-body mb-4" style="line-height: 1.8;">${textContent}</p>`;
    })
    .join('');
}

const formatDate = (dateString: string) => {
  const d = new Date(dateString);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};

const heroImage = post.heroImage
  ? urlFor(post.heroImage).width(1200).format('webp').url()
  : 'https://cdn.sanity.io/images/fkqsnbt5/production/e6ee1ed4a3897a23de35c904a970b341106a934f-1024x682.jpg?w=1200&auto=format';
const author = post.author || 'Thomas A. McGovern';
const tags = post.tags || [];
const bodyHtml = renderPortableText(post.body);
---

<Layout
  title={post.seoTitle || `${post.title} — Thomas McGovern CPA`}
  description={post.seoDescription || post.excerpt || 'Read this article on the Thomas McGovern CPA blog.'}
  ogImage={heroImage}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:author" content={author} />
    <meta property="article:published_time" content={post.publishDate} />
    {tags.length > 0 && <meta property="article:section" content={tags[0]} />}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.title,
      "description": post.excerpt || post.title,
      "image": heroImage,
      "author": { "@type": "Person", "name": author },
      "publisher": { "@type": "Organization", "name": "Thomas McGovern CPA", "url": "https://thomasmcgovern.cpa" },
      "url": `https://thomasmcgovern.cpa/blog/${slug}`,
      "datePublished": post.publishDate
    })}></script>
  </Fragment>

  <main>
    <!-- HERO -->
    <section class="relative flex items-end justify-center" style="padding-top: 150px; padding-bottom: 100px;">
      <div class="absolute inset-0 z-0">
        <img src={heroImage} alt={post.heroImage?.alt || post.title} class="w-full h-full object-cover" />
        <div class="absolute inset-0" style="background: linear-gradient(#03213a, rgba(1, 83, 121, 0.79));"></div>
      </div>
      <div class="container-site relative z-10 text-center">
        <h1 class="text-hero-heading text-[28px] lg:text-[40px]" style="font-family: var(--font-heading);">{post.title}</h1>
      </div>
    </section>

    <!-- POST CONTENT -->
    <section style="padding-top: 60px; padding-bottom: 60px;">
      <div class="container-site" style="max-width: 800px;">
        <a href="/blogs" class="text-primary hover:text-accent transition-colors text-sm font-semibold" style="font-family: var(--font-narrow);">&larr; Back to Blogs</a>

        <div class="mt-4 mb-8 flex items-center gap-3 text-sm text-gray-500 border-b border-border pb-6" style="font-family: var(--font-body);">
          <span>By <strong class="text-primary">{author}</strong></span>
          <span>&middot;</span>
          <span>{formatDate(post.publishDate)}</span>
        </div>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-8">
            {tags.map((tag: string) => (
              <span class="text-xs font-semibold text-primary bg-gray-100 rounded-full px-3 py-1" style="font-family: var(--font-narrow);">{tag}</span>
            ))}
          </div>
        )}

        {bodyHtml ? (
          <div set:html={bodyHtml} />
        ) : (
          <p class="text-body text-gray-500 italic">This post is coming soon.</p>
        )}
      </div>
    </section>
  </main>
</Layout>
