---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Contact Us — Thomas McGovern CPA"
  description="Get in touch with Thomas McGovern about Road to the Final Hour, speaking engagements, or media inquiries."
>
  <main>

    <!-- HERO with gradient overlay -->
    <section class="relative" style="padding-top: 230px; padding-bottom: 85px;">
      <div class="absolute inset-0 z-0">
        <img
          src="https://cdn.sanity.io/images/fkqsnbt5/production/0004aaa0606f12ba8d4913bdd1115ed1a884d984-1024x250.jpg?w=1600&auto=format"
          alt=""
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0" style="background: linear-gradient(#03213a, rgba(1, 83, 121, 0.79));"></div>
      </div>
      <div class="container-site relative z-10">
        <h1 class="text-hero-heading text-[28px] lg:text-[40px]" style="font-family: var(--font-heading);">Contact Us</h1>
        <p class="text-footer-text text-[13px] lg:text-[14px] mt-2" style="font-family: var(--font-body);"><a href="/" class="hover:text-accent transition-colors" style="color: #f5f5f5; text-decoration: none;">Home</a><span style="margin: 0 8px; color: #f5f5f5;">/</span><span style="color: #f5f5f5;">Contact Us</span></p>
      </div>
    </section>

    <!-- CONTACT CONTENT -->
    <section style="padding-top: 60px; padding-bottom: 60px;">
      <div class="container-site">
        <div class="flex flex-col-reverse lg:flex-row flex-wrap justify-between">
          <!-- Left sidebar: contact info -->
          <div class="w-full lg:w-[30%] lg:pr-10 lg:border-r" style="border-color: rgba(158,158,158,0.22);">
            <h2 class="text-primary text-[25px]" style="font-family: var(--font-heading);">Contact Info</h2>
            <div class="flex items-center gap-3 mt-2.5" style="font-family: var(--font-narrow); font-size: 18px;">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <a href="mailto:tmcgovern@thomasmcgovern.cpa" class="hover:text-accent transition-colors" style="font-family: var(--font-narrow);">tmcgovern@thomasmcgovern.cpa</a>
            </div>

            <hr class="my-10" style="border-color: rgba(97,97,97,0.1);" />

            <h2 class="text-primary text-[25px]" style="font-family: var(--font-heading);">Follow Us</h2>
            <ul class="mt-2.5 space-y-2.5">
              <li>
                <a href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer" class="block text-white py-3.5 px-4" style="background-color: #3b5998; font-family: var(--font-narrow); font-size: 16px;">Facebook</a>
              </li>
              <li>
                <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" class="block text-white py-3.5 px-4" style="background-color: #4E433C; font-family: var(--font-narrow); font-size: 16px;">Instagram</a>
              </li>
            </ul>

            <hr class="my-10" style="border-color: rgba(97,97,97,0.1);" />

            <h3 class="text-primary text-[20px]" style="font-family: var(--font-heading); width: 100%; margin-top: 10px;">The Future of College Sports Hangs in the Balance</h3>
            <a href="https://www.amazon.com/dp/B0DWDWWDY1" target="_blank" rel="noopener noreferrer" class="btn-primary mt-5 inline-block text-[13px]" style="font-size: 13px;">Buy the Book</a>
          </div>

          <!-- Right: contact form -->
          <div class="w-full lg:w-[70%] lg:pl-10">
            <h2 class="text-primary text-[25px] mb-10" style="font-family: var(--font-heading);">Get in Touch with us</h2>
            <form class="space-y-5" style="font-family: var(--font-body);">
              <div class="flex flex-col sm:flex-row gap-2.5">
                <div class="w-full sm:w-1/2">
                  <input
                    type="text"
                    name="name"
                    required
                    placeholder="Name"
                    class="w-full px-3 py-3 border border-border bg-white text-body focus:outline-none focus:ring-2 focus:ring-primary"
                    style="font-family: var(--font-body); color: var(--color-body);"
                  />
                </div>
                <div class="w-full sm:w-1/2">
                  <input
                    type="email"
                    name="email"
                    required
                    placeholder="Email *"
                    class="w-full px-3 py-3 border border-border bg-white text-body focus:outline-none focus:ring-2 focus:ring-primary"
                    style="font-family: var(--font-body); color: var(--color-body);"
                  />
                </div>
              </div>
              <div>
                <input
                  type="tel"
                  name="phone"
                  placeholder="Phone Number"
                  class="w-full px-3 py-3 border border-border bg-white text-body focus:outline-none focus:ring-2 focus:ring-primary"
                  style="font-family: var(--font-body); color: var(--color-body);"
                />
              </div>
              <div>
                <textarea
                  name="message"
                  rows="6"
                  required
                  placeholder="Message"
                  class="w-full px-3 py-3 border border-border bg-white text-body focus:outline-none focus:ring-2 focus:ring-primary resize-vertical"
                  style="font-family: var(--font-body); color: var(--color-body);"
                ></textarea>
              </div>
              <div>
                <button
                  type="submit"
                  class="px-8 py-3 bg-primary text-white font-bold uppercase transition-colors hover:bg-primary-dark"
                  style="font-family: var(--font-narrow); font-size: 18px; min-height: 48px;"
                >Submit</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>
