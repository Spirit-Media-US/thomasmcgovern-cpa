---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const success = Astro.url.searchParams.get('success') === 'true';
---

<Layout
  title="Contact Us — Thomas McGovern CPA"
  description="Get in touch with Thomas McGovern about Road to the Final Hour, speaking engagements, or media inquiries."
>
  <main>

    <!-- HERO with gradient overlay -->
    <section class="relative" style="padding-top: 230px; padding-bottom: 85px;">
      <div class="absolute inset-0 z-0">
        <img
          src="https://cdn.sanity.io/images/fkqsnbt5/production/0004aaa0606f12ba8d4913bdd1115ed1a884d984-1024x250.jpg?w=1600&auto=format"
          alt=""
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0" style="background: linear-gradient(#03213a, rgba(1, 83, 121, 0.79));"></div>
      </div>
      <div class="container-site relative z-10">
        <h1 class="text-hero-heading text-[28px] lg:text-[40px]" style="font-family: var(--font-heading);">Contact Us</h1>
        <p class="text-footer-text text-[13px] lg:text-[14px] mt-2" style="font-family: var(--font-body);"><a href="/" class="hover:text-accent transition-colors" style="color: #f5f5f5; text-decoration: none;">Home</a><span style="margin: 0 8px; color: #f5f5f5;">/</span><span style="color: #f5f5f5;">Contact Us</span></p>
      </div>
    </section>

    <!-- CONTACT CONTENT -->
    <section style="padding-top: 60px; padding-bottom: 60px;">
      <div class="container-site">
        <div class="flex flex-col-reverse lg:flex-row flex-wrap justify-between gap-10 lg:gap-0">
          <!-- Left sidebar: contact info -->
          <div class="w-full lg:w-[30%] lg:pr-10 lg:border-r" style="border-color: rgba(158,158,158,0.22);">
            <h2 class="text-primary text-[25px]" style="font-family: var(--font-heading);">Contact Info</h2>
            <div class="flex items-center gap-3 mt-2.5" style="font-family: var(--font-narrow); font-size: 18px;">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <a href="mailto:tmcgovern@thomasmcgovern.cpa" class="hover:text-accent transition-colors" style="font-family: var(--font-narrow);">tmcgovern@thomasmcgovern.cpa</a>
            </div>

            <hr class="my-10" style="border-color: rgba(97,97,97,0.1);" />

            <h2 class="text-primary text-[25px]" style="font-family: var(--font-heading);">Follow Us</h2>
            <div class="mt-2.5" style="display: flex; flex-direction: row; gap: 0;">
              <a href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer" class="text-white py-3.5 px-4" style="background-color: #3b5998; font-family: var(--font-narrow); font-size: 16px;">Facebook</a>
              <a href="https://x.com/" target="_blank" rel="noopener noreferrer" class="text-white py-3.5 px-4" style="background-color: #000000; font-family: var(--font-narrow); font-size: 16px;">Twitter</a>
              <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" class="text-white py-3.5 px-4" style="background-color: #4E433C; font-family: var(--font-narrow); font-size: 16px;">Instagram</a>
              <a href="https://www.youtube.com/" target="_blank" rel="noopener noreferrer" class="text-white py-3.5 px-4" style="background-color: #FF0000; font-family: var(--font-narrow); font-size: 16px;">YouTube</a>
            </div>

            <hr class="my-10" style="border-color: rgba(97,97,97,0.1);" />

            <img
              src="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=200&auto=format"
              alt="Road to the Final Hour"
              style="width: 160px; margin-bottom: 10px; filter: drop-shadow(0 4px 10px rgba(0,0,0,0.4));"
            />
            <h3 class="text-primary text-[20px]" style="font-family: var(--font-heading); width: 100%; margin-top: 10px;">The Future of College Sports Hangs in the Balance</h3>
            <a href="https://www.amazon.com/dp/B0DWDWWDY1" target="_blank" rel="noopener noreferrer" class="btn-primary mt-5 inline-block text-[13px]" style="font-size: 13px;">Buy the Book <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 448 512" fill="currentColor" style="display:inline;vertical-align:middle;margin-left:6px;"><path d="M257.2 162.7c-48.7 1.8-169.5 15.5-169.5 117.5 0 109.5 138.3 114 183.5 43.2 6.5 10.2 35.4 37.5 45.3 46.8l56.8-56S341 288.9 341 261.4V114.3C341 89 316.5 32 228.7 32 140.7 32 94 87 94 136.3l73.5 6.8c16.3-49.5 54.2-49.5 54.2-49.5 40.7-.1 35.5 29.8 35.5 69.1zm0 86.8c0 80-84.2 68-84.2 17.2 0-47.2 50.5-56.7 84.2-57.8v40.6zm136 163.5c-7.7 10-70 67-174.5 67S34.2 408.5 9.7 379c-6.8-7.7 1-11.3 5.5-8.3C88.5 415.2 203 488.5 387.7 401c7.5-3.7 13.3 2 5.5 12zm39.8-13.7c-9.8-7.5-32.4-14.3-51-7.7-5.7 1.8-5 6.3-1.3 7.7 10.2 3.3 33.4 10 46.3 7.5 12.7-2.3 13.7-3.7 6-7.5z"/></svg></a>
          </div>

          <!-- Right: contact form -->
          <div class="w-full lg:w-[70%] lg:pl-10">
            <h2 class="text-primary text-[25px] mb-10" style="font-family: var(--font-heading);">Get in Touch with us</h2>
            {success && (
              <div class="mb-8 p-4 bg-green-50 border border-green-200 text-green-800" style="font-family: var(--font-body);">
                Thank you for your message! We'll get back to you soon.
              </div>
            )}
            <form action="/api/contact" method="POST" class="space-y-5" style="font-family: var(--font-body);">
              <div class="flex flex-col sm:flex-row gap-2.5">
                <div class="w-full sm:w-1/2">
                  <input
                    type="text"
                    name="name"
                    required
                    placeholder="Name"
                    class="w-full px-3 py-3 border border-border bg-white text-body focus:outline-none focus:ring-2 focus:ring-primary"
                    style="font-family: var(--font-body); color: var(--color-body);"
                  />
                </div>
                <div class="w-full sm:w-1/2">
                  <input
                    type="email"
                    name="email"
                    required
                    placeholder="Email *"
                    class="w-full px-3 py-3 border border-border bg-white text-body focus:outline-none focus:ring-2 focus:ring-primary"
                    style="font-family: var(--font-body); color: var(--color-body);"
                  />
                </div>
              </div>
              <div>
                <input
                  type="tel"
                  name="phone"
                  placeholder="Phone Number"
                  class="w-full px-3 py-3 border border-border bg-white text-body focus:outline-none focus:ring-2 focus:ring-primary"
                  style="font-family: var(--font-body); color: var(--color-body);"
                />
              </div>
              <div>
                <textarea
                  name="message"
                  rows="6"
                  required
                  placeholder="Message"
                  class="w-full px-3 py-3 border border-border bg-white text-body focus:outline-none focus:ring-2 focus:ring-primary resize-vertical"
                  style="font-family: var(--font-body); color: var(--color-body);"
                ></textarea>
              </div>
              <div>
                <button
                  type="submit"
                  class="btn-primary px-8 py-3 font-bold w-full"
                >Send <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-left:6px;"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg></button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>
