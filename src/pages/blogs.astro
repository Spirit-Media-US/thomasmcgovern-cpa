---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { sanityClient } from '../lib/sanity.ts';

const blogPosts = await sanityClient.fetch(`
  *[_type == "blogPost"] | order(publishDate desc) {
    title,
    "slug": "/blog/" + slug.current,
    "image": heroImage.asset->url + "?w=600&auto=format",
    "date": publishDate,
    excerpt
  }
`);

const formatDate = (dateString: string) => {
  const d = new Date(dateString);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<Layout
  title="Blogs — Thomas McGovern CPA"
  description="Articles and insights on college sports, taxation, and the future of NCAA athletics by Thomas McGovern."
>
  <main>

    <!-- HERO with gradient overlay -->
    <section class="relative" style="padding-top: 150px; padding-bottom: 75px;" id="blogs-hero">
      <div class="absolute inset-0 z-0">
        <img
          src="https://cdn.sanity.io/images/fkqsnbt5/production/f0c71bb26dade9d1168670a9184fdd8684a8a45c-958x518.webp?w=1600&auto=format"
          alt=""
          class="w-full h-full object-cover object-right"
        />
        <div class="absolute inset-0" style="background: linear-gradient(#03213a, rgba(1, 83, 121, 0.79));"></div>
      </div>
      <div class="container-site relative z-10 text-left">
        <h1 class="text-hero-heading text-[28px] lg:text-[40px]" style="font-family: var(--font-heading);">Blogs</h1>
        <p class="text-footer-text text-[13px] lg:text-[14px] mt-2" style="font-family: var(--font-body);"><a href="/" class="hover:text-accent transition-colors" style="color: #f5f5f5; text-decoration: none;">Home</a><span style="margin: 0 8px; color: #f5f5f5;">/</span><span style="color: #f5f5f5;">Blogs</span></p>
      </div>
    </section>

    <!-- BLOG CONTENT -->
    <section style="padding-top: 60px; padding-bottom: 60px;">
      <div class="container-site">
        <div class="flex flex-col lg:flex-row gap-10">
          <!-- Left: blog posts -->
          <div class="w-full lg:w-[70%]">
            <div class="space-y-10">
              {blogPosts.map((post: any) => (
                <article class="bg-white card-shadow overflow-hidden">
                  <div class="h-[300px] overflow-hidden">
                    <img src={post.image} alt={post.title} class="w-full h-full object-cover" />
                  </div>
                  <div class="p-6">
                    <p class="text-gray-500 text-sm mb-2" style="font-family: var(--font-body);">{formatDate(post.date)}</p>
                    <h2 class="text-primary text-[20px] lg:text-[25px] font-semibold leading-snug" style="font-family: var(--font-body);">{post.title}</h2>
                    {post.excerpt && <p class="text-gray-600 text-sm mt-2" style="font-family: var(--font-body);">{post.excerpt}</p>}
                    <a href={post.slug} class="btn-primary mt-5 inline-block text-[15px]" style="padding: 8px 16px; font-size: 15px;">Read More ...</a>
                  </div>
                </article>
              ))}
            </div>
          </div>

          <!-- Right sidebar -->
          <div class="w-full lg:w-[30%]">
            <!-- Search -->
            <div class="mb-8">
              <h3 class="text-primary text-[20px] mb-4" style="font-family: var(--font-heading);">Search Keywords</h3>
              <form class="flex gap-2">
                <input
                  type="search"
                  placeholder="Search..."
                  class="flex-1 px-3 py-2 border border-border bg-white text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                  style="font-family: var(--font-body);"
                />
                <button type="submit" class="btn-primary px-3 py-2" aria-label="Search"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></button>
              </form>
            </div>

            <!-- Recent Blogs -->
            <div>
              <h3 class="text-primary text-[20px] mb-4" style="font-family: var(--font-heading);">Recent Blogs</h3>
              <ul class="space-y-4">
                {blogPosts.map((post: any) => (
                  <li>
                    <a href={post.slug} class="text-primary hover:text-accent transition-colors text-[16px] font-semibold" style="font-family: var(--font-body);">{post.title}</a>
                    <p class="text-gray-500 text-sm mt-1" style="font-family: var(--font-body);">{formatDate(post.date)}</p>
                  </li>
                ))}
              </ul>
            </div>

            <hr style="border-color: rgba(97,97,97,0.1); margin: 40px 0;" />

            <!-- Book CTA -->
            <div>
              <img
                src="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=300&auto=format"
                alt="Road to the Final Hour"
                style="width: 220px; margin-bottom: 10px; filter: drop-shadow(0 4px 10px rgba(0,0,0,0.4));"
              />
              <h3 class="text-primary text-[20px]" style="font-family: var(--font-heading); margin-top: 10px;">The Future of College Sports Hangs in the Balance</h3>
              <a href="https://www.amazon.com/dp/B0DWDWWDY1" target="_blank" rel="noopener noreferrer" class="btn-primary mt-5 inline-block text-[13px]" style="font-size: 13px;">Buy the Book <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 448 512" fill="currentColor" style="display:inline;vertical-align:middle;margin-left:6px;"><path d="M257.2 162.7c-48.7 1.8-169.5 15.5-169.5 117.5 0 109.5 138.3 114 183.5 43.2 6.5 10.2 35.4 37.5 45.3 46.8l56.8-56S341 288.9 341 261.4V114.3C341 89 316.5 32 228.7 32 140.7 32 94 87 94 136.3l73.5 6.8c16.3-49.5 54.2-49.5 54.2-49.5 40.7-.1 35.5 29.8 35.5 69.1zm0 86.8c0 80-84.2 68-84.2 17.2 0-47.2 50.5-56.7 84.2-57.8v40.6zm136 163.5c-7.7 10-70 67-174.5 67S34.2 408.5 9.7 379c-6.8-7.7 1-11.3 5.5-8.3C88.5 415.2 203 488.5 387.7 401c7.5-3.7 13.3 2 5.5 12zm39.8-13.7c-9.8-7.5-32.4-14.3-51-7.7-5.7 1.8-5 6.3-1.3 7.7 10.2 3.3 33.4 10 46.3 7.5 12.7-2.3 13.7-3.7 6-7.5z"/></svg></a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- NEWSLETTER -->
    <section style="position: relative; padding: 30px 0; background: #000000;">
      <div class="container-site relative z-10">
        <div style="display: flex; flex-direction: row; align-items: center; justify-content: space-between; gap: 2rem;" class="newsletter-row-blog">
          <div>
            <p style="font-family: var(--font-narrow); font-size: clamp(18px, 3.5vw, 27px); color: #f5f5f5;">Stay updated with upcoming book events, author appearances, and media features.</p>
          </div>
          <div style="width: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: flex-end;" class="newsletter-form-wrap-blog">
            <form action="/api/newsletter" method="POST" style="display: flex; flex-direction: column; gap: 12px; width: 85%;">
              <input
                type="email"
                name="email"
                placeholder="Your Email"
                required
                style="width: 100%; padding: 14px 16px; font-size: 16px; border: 0; outline: none; font-family: var(--font-body); background: #fff; color: #212121; box-sizing: border-box;"
              />
              <button
                type="submit"
                style="width: 100%; min-height: 48px; padding: 14px 16px; font-size: 16px; font-family: var(--font-narrow); font-weight: 700; text-transform: uppercase; background: #ffc107; color: #000; border: none; cursor: pointer; letter-spacing: 1px;"
              >Sign Up</button>
            </form>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  @media (min-width: 1024px) {
    #blogs-hero {
      padding-top: 230px !important;
    }
  }
  @media (max-width: 768px) {
    .newsletter-row-blog {
      flex-direction: column !important;
      text-align: center;
      gap: 20px !important;
    }
    .newsletter-form-wrap-blog {
      width: 100% !important;
      justify-content: center !important;
    }
    .newsletter-form-wrap-blog form {
      width: 100% !important;
    }
  }
</style>
