---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const testimonials = [
  {
    quote: 'A must-read for anyone who cares about the future of college sports.',
    name: 'Dr. Jane Smith',
    role: 'Sports Economist',
  },
  {
    quote: 'This book masterfully explains the challenges facing intercollegiate athletics and why action is needed now.',
    name: 'John Doe',
    role: 'University President',
  },
  {
    quote: 'Eye-opening and thought-provoking. A game-changer for understanding college athletics.',
    name: 'Sarah T.',
    role: 'Reader',
  },
];

const blogPosts = [
  {
    title: '5 Myths About Professionalizing College Sports',
    image: 'https://cdn.sanity.io/images/fkqsnbt5/production/b89d10e302b00d8827e6f032cf74c0303fdae6db-1024x576.jpg?w=600&auto=format',
  },
  {
    title: 'The Tax Debate That Could Change NCAA Forever',
    image: 'https://cdn.sanity.io/images/fkqsnbt5/production/aa049e72dd99d4499adee9b279aad23ea55a1ab2-640x427.jpg?w=600&auto=format',
  },
  {
    title: 'Why Title IX Could Be the Sleeper Issue in the NCAA Professionalization Debate',
    image: 'https://cdn.sanity.io/images/fkqsnbt5/production/e6ee1ed4a3897a23de35c904a970b341106a934f-1024x682.jpg?w=600&auto=format',
  },
];

const bookshopUrl = 'https://cdn.sanity.io/images/fkqsnbt5/production/8965c4837800b4f95b98cf3bbb3a231e04c7fea0-1288x194.png?h=60&auto=format';
const amazonUrl = 'https://cdn.sanity.io/images/fkqsnbt5/production/70d6a0a7825b64ac2411266758c020f8d8917a17-700x211.png?h=60&auto=format';
const barnesUrl = 'https://cdn.sanity.io/images/fkqsnbt5/production/629e606064be46ec62ed9b5d533dd5239287a89d-1536x864.png?h=60&auto=format';
---

<Layout title="Thomas McGovern CPA — Road to the Final Hour">
  <main>

    <!-- HERO -->
    <section class="hero-section">
      <div class="hero-inner container-site">
        <div class="hero-content">
          <!-- Left: book cover -->
          <div class="hero-image">
            <img
              src="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=500&auto=format"
              alt="Road to the Final Hour book cover"
            />
          </div>
          <!-- Right: text -->
          <div class="hero-text">
            <h5 class="hero-eyebrow">ORDER NOW</h5>
            <h1 class="hero-heading">The Future of College Sports Hangs in the Balance</h1>
            <p class="hero-body">Discover how taxation, professionalization, and legislation could transform the game forever.</p>
            <a href="https://www.amazon.com/dp/B0DWDWWDY1" target="_blank" rel="noopener noreferrer" class="btn-primary" style="margin-top: 24px;">Buy the Book</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURED IN LOGOS -->
    <section class="featured-strip">
      <div class="container-site">
        <div class="featured-strip-inner">
          <img src={barnesUrl} alt="Barnes & Noble" class="featured-logo featured-logo-barnes" />
          <img src={bookshopUrl} alt="Bookshop" class="featured-logo" />
          <img src={amazonUrl} alt="Amazon" class="featured-logo featured-logo-amazon" />
          <img src={barnesUrl} alt="Barnes & Noble" class="featured-logo featured-logo-barnes" />
          <img src={bookshopUrl} alt="Bookshop" class="featured-logo" />
        </div>
      </div>
    </section>

    <!-- ABOUT ME -->
    <section id="about-me" class="about-section">
      <div class="container-site">
        <p class="eyebrow mb-2">WHAT I DO</p>
        <h2 class="heading-section mb-0">About <span>&nbsp;</span>Me</h2>

        <hr class="section-divider" />

        <div class="about-row">
          <!-- Left: bio text (57%) -->
          <div class="about-left">
            <h3 class="heading-sub mb-5">About Me</h3>
            <p class="text-body">
              Thomas A. McGovern is a Certified Public Accountant (CPA) and holds the Chartered Financial Analyst (CFA) designation. His extensive career includes twenty years as a Wall Street investment banker and equity research analyst. He has been involved in the higher education sector as a member of the board of directors of the University of Virginia's Manhattan alumni group, the Virginia Club of New York, and President of the Board of Governors of the St. Elmos national organization. Thomas McGovern earned a Master of Business Administration (MBA) from the Darden Graduate School of Business at the University of Virginia and an AB in Economics from Hamilton College where he graduated summa cum laude.
            </p>

            <hr class="section-divider" />

            <h3 class="heading-sub mb-5">Featured In:</h3>
            <div class="featured-carousel">
              <img src="https://cdn.sanity.io/images/fkqsnbt5/production/7c842983b4df241aa093074c7edc8353213baf1c-750x333.png?h=40&auto=format" alt="ESPN" class="carousel-logo" />
              <img src="https://cdn.sanity.io/images/fkqsnbt5/production/38c6673397633951ff7e2ae5b0f2bc49d9754876-3840x2160.png?h=40&auto=format" alt="Wall Street Journal" class="carousel-logo" />
              <img src="https://cdn.sanity.io/images/fkqsnbt5/production/820cf4a6fc991d2b9b92fcd1d1a436192854fe01-4736x886.png?h=40&auto=format" alt="USA Today" class="carousel-logo" />
            </div>
          </div>

          <!-- Right: headshot (40%) -->
          <div class="about-right">
            <div class="about-photo-wrapper">
              <img
                src="https://cdn.sanity.io/images/fkqsnbt5/production/fddd87a4ca10681a164c04643a9aa0deecbfe532-1200x1800.jpg?w=600&auto=format"
                alt="Thomas A. McGovern"
                class="about-photo"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="stats-section">
      <div class="container-site">
        <div class="stats-row">
          <div class="stat-item">
            <div class="stat-number"><span class="stat-count" data-target="25">25</span><span class="stat-suffix">+</span></div>
            <p class="stat-label">Years of Experienced</p>
          </div>
          <div class="stat-item">
            <div class="stat-number"><span class="stat-count" data-target="3">3</span><span class="stat-suffix">+</span></div>
            <p class="stat-label">Books Written</p>
          </div>
          <div class="stat-item">
            <div class="stat-number"><span class="stat-count" data-target="3">3</span><span class="stat-suffix">K +</span></div>
            <p class="stat-label">Happy Readers</p>
          </div>
          <div class="stat-item">
            <div class="stat-number"><span class="stat-count" data-target="12">12</span><span class="stat-suffix">+</span></div>
            <p class="stat-label">Awards Recognitions</p>
          </div>
        </div>
      </div>
    </section>

    <!-- BOOK SECTION -->
    <section class="book-section">
      <div class="container-site">
        <p class="eyebrow mb-2">SHOWCASE</p>
        <h2 class="heading-section">About the <span>&nbsp;</span>Book</h2>

        <!-- Overview: image left + text right -->
        <div class="book-overview card-shadow-light">
          <div class="book-overview-image" style="background-image: url('https://cdn.sanity.io/images/fkqsnbt5/production/83fb29edffe6af52b5b8c5ef2cd51d56f4c72ef9-1024x510.png?w=800&auto=format');"></div>
          <div class="book-overview-text">
            <h3 class="heading-sub-sm mb-5">Overview</h3>
            <p class="text-body">
              Discover Road to the Final Hour, an in-depth exploration of the forces threatening to reshape college athletics. From taxation to professionalization, this book unpacks the complexities of the current landscape and provides a compelling case for preserving the spirit of college sports.
            </p>
          </div>
        </div>

        <!-- Quote block -->
        <div class="card-shadow-light mt-12 p-0">
          <p class="quote-text">
            &ldquo;College sports are at a crossroads, and how we address these challenges will define the future of intercollegiate athletics for generations to come.&rdquo;
          </p>
          <p class="quote-attribution">- Thomas A. McGovern</p>
        </div>

        <!-- Chapters Preview: text+button left, book cover right, icon cards below -->
        <div class="chapters-row">
          <div class="chapters-text">
            <h3 class="heading-sub mb-5">Chapters Preview</h3>
            <p class="text-body">Discover how taxation, professionalization, and legislation could transform the game forever.</p>
            <a href="https://www.amazon.com/dp/B0DWDWWDY1" target="_blank" rel="noopener noreferrer" class="btn-primary mt-5 inline-block">Buy the Book</a>
          </div>
          <div class="chapters-image">
            <img
              src="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=500&auto=format"
              alt="Road to the Final Hour book cover"
            />
          </div>
        </div>

        <!-- 3 Chapter icon cards -->
        <div class="chapter-cards">
          <div class="chapter-card card-shadow">
            <div class="chapter-card-inner">
              <span class="chapter-icon">&#10004;</span>
              <div>
                <h4 class="chapter-card-title"><em>The Labor Issue</em></h4>
                <p class="chapter-card-text">Examines the push to classify college athletes as employees and its implications.</p>
              </div>
            </div>
          </div>
          <div class="chapter-card card-shadow">
            <div class="chapter-card-inner">
              <span class="chapter-icon">&#10004;</span>
              <div>
                <h4 class="chapter-card-title"><em>Effects of Taxation</em></h4>
                <p class="chapter-card-text">Unpacks how UBTI and loss of tax-exempt status could cripple the industry.</p>
              </div>
            </div>
          </div>
          <div class="chapter-card card-shadow">
            <div class="chapter-card-inner">
              <span class="chapter-icon">&#10004;</span>
              <div>
                <h4 class="chapter-card-title"><em>The Bigger Issue</em></h4>
                <p class="chapter-card-text">Explores the ideological battle over the value of college sports in society.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- THE ISSUES -->
    <section class="issues-section">
      <div class="container-site relative z-10">
        <p class="eyebrow mb-2">MORE INFO ABOUT THE BOOK</p>
        <h2 class="heading-section">The Issues</h2>

        <!-- Infographic -->
        <div class="mt-8 mb-8">
          <img
            src="https://cdn.sanity.io/images/fkqsnbt5/production/be37419005c1c164a021dca8ff787c180c7f8f04-1200x456.png?w=1000&auto=format"
            alt="Before Infographic"
            class="w-full"
          />
        </div>

        <!-- Tax-exempt status -->
        <h3 class="heading-sub">What Happens When College Athletics Lose Tax-Exempt Status?</h3>
        <p class="text-body mt-5">
          The imposition of Unrelated Business Income Tax (UBTI) could drastically alter the financial foundation of college sports. A 21% federal corporate tax, combined with state taxes, would reduce funds available for non revenue sports and student-athlete scholarships.
        </p>

        <hr class="section-divider-thin" />

        <!-- Cultural significance: image left + text right -->
        <div class="issues-row card-shadow-light">
          <div class="issues-row-image" style="background-image: url('https://cdn.sanity.io/images/fkqsnbt5/production/f0837f92d1e3259acfb59d8fef4a20d945ba4dfb-660x440.webp?w=800&auto=format');"></div>
          <div class="issues-row-text">
            <h3 class="heading-sub" style="width: 75%;">Cultural Significance of College Athletics</h3>
            <p class="text-body mt-5">
              &ldquo;More Than a Game&rdquo; College athletics produce Olympians, foster teamwork, and teach life skills. Cutting programs would not only hurt athletes but also the broader educational mission of U.S. universities.
            </p>
          </div>
        </div>

        <hr class="section-divider-thin" />

        <!-- Scenario cards -->
        <h3 class="heading-sub-sm mb-5">Two Scenarios for Professionalization</h3>

        <div class="scenario-row">
          <div class="scenario-card">
            <p class="heading-gray">Scenario 1</p>
            <p class="text-body mt-2.5">Professionalizing only revenue sports like football and basketball.</p>
          </div>
          <div class="scenario-card">
            <p class="heading-gray">Scenario 2</p>
            <p class="text-body mt-2.5">Professionalizing all intercollegiate sports, with catastrophic financial consequences.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="testimonials-section">
      <div class="testimonials-overlay"></div>
      <div class="container-site relative z-10">
        <div class="text-center">
          <p class="eyebrow mb-2">WHAT OTHER SAYS</p>
          <h2 class="heading-section mb-10">Testimonials</h2>
        </div>

        <div class="relative">
          <!-- Map background -->
          <div class="testimonials-map" aria-hidden="true">
            <img src="https://cdn.sanity.io/images/fkqsnbt5/production/42dc40b9bcf0e0e58aa5ef120bec670620a821d2-770x380.png?w=600&auto=format" alt="" class="w-full max-w-xl object-contain" />
          </div>

          <div id="testimonial-slider" class="relative max-w-3xl mx-auto">
            {testimonials.map((t, i) => (
              <div class:list={['testimonial-slide', { hidden: i !== 0 }]} data-index={i}>
                <blockquote class="text-center px-8">
                  <p class="testimonial-quote">
                    &ldquo;{t.quote}&rdquo;
                  </p>
                  <footer>
                    <p class="testimonial-name">{t.name}</p>
                    <p class="testimonial-role">{t.role}</p>
                  </footer>
                </blockquote>
              </div>
            ))}

            <!-- Navigation dots -->
            <div class="flex justify-center gap-3 mt-8">
              {testimonials.map((_, i) => (
                <button
                  class:list={['testimonial-dot w-3 h-3 rounded-full transition-colors', i === 0 ? 'bg-primary' : 'bg-gray-300']}
                  data-dot={i}
                  aria-label={`Testimonial ${i + 1}`}
                />
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BLOG POSTS -->
    <section class="blog-section">
      <div class="container-site">
        <div class="text-center">
          <p class="eyebrow mb-2">ARCHIVES</p>
          <h2 class="heading-section mb-10">Blog & News</h2>
        </div>

        <div class="blog-grid">
          {blogPosts.map(post => (
            <div class="blog-card">
              <div class="blog-card-image" style={`background-image: url('${post.image}');`}></div>
              <div class="p-5">
                <h3 class="blog-card-title">{post.title}</h3>
                <a href="/blogs" class="btn-primary blog-card-btn">Read more ...</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- NEWSLETTER -->
    <section class="newsletter-section">
      <div class="newsletter-overlay"></div>
      <div class="container-site relative z-10">
        <div class="newsletter-row">
          <div>
            <p class="newsletter-heading">Stay updated with upcoming book events, author appearances, and media features.</p>
          </div>
          <div class="newsletter-form-wrapper">
            <form class="newsletter-form">
              <input
                type="email"
                placeholder="Your Email"
                required
                class="newsletter-input"
              />
              <button
                type="submit"
                class="btn-primary"
              >Sign Up</button>
            </form>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  // Testimonial slider
  let current = 0;
  const slides = document.querySelectorAll('.testimonial-slide');
  const dots = document.querySelectorAll('.testimonial-dot');

  function showSlide(idx: number) {
    slides.forEach((s, i) => {
      (s as HTMLElement).classList.toggle('hidden', i !== idx);
    });
    dots.forEach((d, i) => {
      d.classList.toggle('bg-primary', i === idx);
      d.classList.toggle('bg-gray-300', i !== idx);
    });
    current = idx;
  }

  dots.forEach(d => {
    d.addEventListener('click', () => {
      showSlide(Number((d as HTMLElement).dataset.dot));
    });
  });

  // Auto-advance every 5 seconds
  setInterval(() => {
    showSlide((current + 1) % slides.length);
  }, 5000);

  // Counter animation
  function animateCounters() {
    const counters = document.querySelectorAll('.stat-count');
    counters.forEach(counter => {
      const el = counter as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      const duration = 1000;
      const startTime = performance.now();

      function update(currentTime: number) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const value = Math.floor(progress * target);
        el.textContent = String(value || 1);
        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          el.textContent = String(target);
        }
      }
      requestAnimationFrame(update);
    });
  }

  // Trigger counters when stats section is visible
  const statsSection = document.querySelector('.stats-section');
  if (statsSection) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounters();
          observer.disconnect();
        }
      });
    }, { threshold: 0.3 });
    observer.observe(statsSection);
  }
</script>

<style>
  /* ===== HERO ===== */
  .hero-section {
    position: relative;
    min-height: 87vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('https://cdn.sanity.io/images/fkqsnbt5/production/fd02252dc714934b8f179eae7c128d1d4e6c3c8a-1024x555.png?w=1920&auto=format');
