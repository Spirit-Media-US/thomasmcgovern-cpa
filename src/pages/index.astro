---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const stats = [
  { value: '1+', label: 'Years Experience' },
  { value: '1+', label: 'Books Written' },
  { value: '1K+', label: 'Happy Readers' },
  { value: '1+', label: 'Awards' },
];

const chapters = [
  {
    icon: '&#9878;', // scales
    title: 'The Labor Issue',
    text: 'Explore how employee classification could fundamentally change the relationship between athletes and universities, with far-reaching implications for the entire system.',
  },
  {
    icon: '&#128176;', // money bag
    title: 'Effects of Taxation',
    text: 'Understand how UBTI (Unrelated Business Taxable Income) and the potential loss of tax-exempt status could reshape college athletics funding and finances.',
  },
  {
    icon: '&#127942;', // trophy
    title: 'The Bigger Issue',
    text: 'Examine the ideological battle at the heart of college sports — where amateurism, commercialism, and the Olympic development pipeline collide.',
  },
];

const testimonials = [
  {
    quote: 'McGovern\'s analysis of the tax implications alone makes this book essential reading for anyone involved in college athletics administration.',
    name: 'Dr. Jane Smith',
    role: 'Sports Economist',
  },
  {
    quote: 'A thorough and thought-provoking examination of the forces that could fundamentally transform college sports as we know them.',
    name: 'John Doe',
    role: 'University President',
  },
  {
    quote: 'Finally, someone who breaks down these complex issues in a way that fans and administrators alike can understand and act upon.',
    name: 'Sarah T.',
    role: 'Reader',
  },
];

const blogPosts = [
  {
    title: '5 Myths About Professionalizing College Sports',
    excerpt: 'Separating fact from fiction in the debate over paying college athletes and what it really means for the future of NCAA sports.',
    image: 'https://cdn.sanity.io/images/fkqsnbt5/production/f0837f92d1e3259acfb59d8fef4a20d945ba4dfb-660x440.webp?w=600&auto=format',
  },
  {
    title: 'The Tax Debate That Could Change NCAA Forever',
    excerpt: 'How UBTI and tax-exempt status are becoming the central battleground for the future of college athletics funding.',
    image: 'https://cdn.sanity.io/images/fkqsnbt5/production/83fb29edffe6af52b5b8c5ef2cd51d56f4c72ef9-1024x510.png?w=600&auto=format',
  },
  {
    title: 'Why Title IX Could Be the Sleeper Issue',
    excerpt: 'As college sports inches toward professionalization, Title IX compliance becomes an even more complex and critical challenge.',
    image: 'https://cdn.sanity.io/images/fkqsnbt5/production/b89d10e302b00d8827e6f032cf74c0303fdae6db-1024x576.jpg?w=600&auto=format',
  },
];

const featuredLogos = [
  { name: 'ESPN', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/7c842983b4df241aa093074c7edc8353213baf1c-750x333.png?h=50&auto=format' },
  { name: 'Wall Street Journal', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/38c6673397633951ff7e2ae5b0f2bc49d9754876-3840x2160.png?h=50&auto=format' },
  { name: 'USA Today', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/820cf4a6fc991d2b9b92fcd1d1a436192854fe01-4736x886.png?h=50&auto=format' },
  { name: 'Forbes', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/f0c71bb26dade9d1168670a9184fdd8684a8a45c-958x518.webp?h=50&auto=format' },
];

const retailers = [
  { name: 'Amazon', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/70d6a0a7825b64ac2411266758c020f8d8917a17-700x211.png?h=40&auto=format', link: 'https://www.amazon.com/dp/B0DWDWWDY1' },
  { name: 'Barnes & Noble', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/629e606064be46ec62ed9b5d533dd5239287a89d-1536x864.png?h=40&auto=format', link: '#' },
  { name: 'Bookshop', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/8965c4837800b4f95b98cf3bbb3a231e04c7fea0-1288x194.png?h=40&auto=format', link: '#' },
];
---

<Layout title="Thomas McGovern CPA — Road to the Final Hour">
  <main>

    <!-- HERO -->
    <section class="relative min-h-[87vh] flex items-center overflow-hidden">
      <!-- Background image + gradient -->
      <div class="absolute inset-0 z-0">
        <img
          src="https://cdn.sanity.io/images/fkqsnbt5/production/e6ee1ed4a3897a23de35c904a970b341106a934f-1024x682.jpg?w=1600&auto=format"
          alt=""
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0" style="background: linear-gradient(#03213a, rgba(1, 83, 121, 0.79));"></div>
      </div>

      <div class="container-site relative z-10 py-24 lg:py-0">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h1 class="text-[30px] lg:text-[45px] leading-[1.1] font-normal text-hero-heading mb-6" style="font-family: var(--font-heading);">
              The Future of College Sports Hangs in the Balance
            </h1>
            <p class="text-lg lg:text-xl text-white/90 mb-8 max-w-xl leading-relaxed">
              Discover how taxation, professionalization, and legislation could transform the game forever.
            </p>
            <a
              href="https://www.amazon.com/dp/B0DWDWWDY1"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-8 py-3.5 bg-accent text-primary-dark font-bold uppercase rounded hover:bg-hero-heading transition-colors"
              style="font-family: var(--font-narrow); font-size: 18px;"
            >Buy the Book</a>
          </div>
          <div class="flex justify-center lg:justify-end">
            <img
              src="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=450&auto=format"
              alt="Road to the Final Hour book cover"
              class="w-[280px] lg:w-[400px] rounded-lg shadow-2xl"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURED IN -->
    <section class="bg-white py-10 border-b border-border">
      <div class="container-site">
        <p class="text-center text-sm text-gray-500 uppercase tracking-widest mb-6" style="font-family: var(--font-narrow);">As Featured In</p>
        <div class="flex items-center justify-center gap-10 lg:gap-16 flex-wrap opacity-60">
          {featuredLogos.map(logo => (
            <img src={logo.url} alt={logo.name} class="h-8 lg:h-12 w-auto object-contain grayscale" />
          ))}
        </div>
      </div>
    </section>

    <!-- ABOUT ME -->
    <section id="about-me" class="py-16 lg:py-20 bg-white">
      <div class="container-site">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="flex justify-center">
            <img
              src="https://cdn.sanity.io/images/fkqsnbt5/production/fddd87a4ca10681a164c04643a9aa0deecbfe532-1200x1800.jpg?w=500&auto=format"
              alt="Thomas A. McGovern"
              class="rounded-2xl shadow-lg w-full max-w-md object-cover"
            />
          </div>
          <div>
            <p class="eyebrow mb-3">About the Author</p>
            <h2 class="heading-section mb-6">About Me</h2>
            <div class="text-body space-y-4">
              <p>
                Thomas A. McGovern holds both CPA and CFA designations, bringing a unique analytical perspective to the intersection of finance and college athletics. With a twenty-year Wall Street career, he combines deep financial expertise with a passion for preserving the integrity of college sports.
              </p>
              <p>
                Tom is actively involved with UVA alumni groups and the St. Elmos organization. He earned his MBA from the Darden Graduate School of Business at the University of Virginia and his AB in Economics from Hamilton College, graduating summa cum laude.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="py-12 lg:py-16" style="background: linear-gradient(135deg, #042a49, #2196f3);">
      <div class="container-site">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center text-white">
          {stats.map(stat => (
            <div>
              <p class="text-[45px] lg:text-[60px] font-bold leading-none mb-2" style="font-family: var(--font-body);">{stat.value}</p>
              <p class="text-[18px] lg:text-[25px] font-bold uppercase" style="font-family: var(--font-narrow);">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- BOOK SECTION -->
    <section class="py-16 lg:py-20 bg-light-bg">
      <div class="container-site">
        <div class="text-center mb-12">
          <p class="eyebrow mb-3">The Book</p>
          <h2 class="heading-section">Road to the Final Hour</h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
          <div>
            <p class="text-body">
              <em>Road to the Final Hour</em> examines the seismic forces threatening to reshape college athletics. From NIL payments and employee classification to tax-exempt status challenges, this book provides a comprehensive analysis of how professionalization could fundamentally alter the landscape of college sports in America.
            </p>
            <div class="mt-8 flex items-center gap-6 flex-wrap">
              {retailers.map(r => (
                <a href={r.link} target="_blank" rel="noopener noreferrer" class="opacity-70 hover:opacity-100 transition-opacity">
                  <img src={r.url} alt={`Buy on ${r.name}`} class="h-8 w-auto object-contain" />
                </a>
              ))}
            </div>
          </div>
          <div class="flex justify-center">
            <img
              src="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=400&auto=format"
              alt="Road to the Final Hour book cover"
              class="w-[300px] rounded-lg shadow-xl"
            />
          </div>
        </div>

        <!-- Chapter previews -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {chapters.map(ch => (
            <div class="bg-white rounded-xl p-8 shadow-[1px_1px_11px_1px_rgba(97,97,97,0.28)] text-center">
              <div class="text-4xl mb-4" set:html={ch.icon} />
              <h3 class="heading-sub text-xl mb-3">{ch.title}</h3>
              <p class="text-body text-base">{ch.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- KEY ISSUES -->
    <section class="py-16 lg:py-20 bg-white">
      <div class="container-site">
        <div class="text-center mb-12">
          <p class="eyebrow mb-3">Key Issues</p>
          <h2 class="heading-section">The Issues That Matter</h2>
        </div>

        <!-- Issue 1 -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
          <div>
            <img
              src="https://cdn.sanity.io/images/fkqsnbt5/production/83fb29edffe6af52b5b8c5ef2cd51d56f4c72ef9-1024x510.png?w=600&auto=format"
              alt="NIL payments to college athletes"
              class="rounded-xl shadow-lg w-full"
            />
          </div>
          <div>
            <h3 class="heading-sub mb-4">Tax-Exempt Status & UBTI</h3>
            <p class="text-body">
              If college athletes are classified as employees, universities could face a 21% federal corporate tax on athletics revenue through Unrelated Business Taxable Income (UBTI). This alone could strip billions from the college sports ecosystem and force dramatic restructuring of athletic departments across the country.
            </p>
          </div>
        </div>

        <!-- Issue 2 -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1">
            <h3 class="heading-sub mb-4">Cultural Significance & Olympic Pipeline</h3>
            <p class="text-body">
              College sports serve as America's primary Olympic development pipeline and hold deep cultural significance in communities across the nation. Professionalization threatens to disrupt this pipeline and fundamentally alter the relationship between universities, athletes, and the communities that rally around their teams.
            </p>
          </div>
          <div class="order-1 lg:order-2">
            <img
              src="https://cdn.sanity.io/images/fkqsnbt5/production/f0837f92d1e3259acfb59d8fef4a20d945ba4dfb-660x440.webp?w=600&auto=format"
              alt="University of Tennessee stadium"
              class="rounded-xl shadow-lg w-full"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="py-16 lg:py-20 bg-light-bg">
      <div class="container-site">
        <div class="text-center mb-12">
          <p class="eyebrow mb-3">What Readers Say</p>
          <h2 class="heading-section">Testimonials</h2>
        </div>

        <div id="testimonial-slider" class="relative max-w-3xl mx-auto">
          {testimonials.map((t, i) => (
            <div class:list={['testimonial-slide', { hidden: i !== 0 }]} data-index={i}>
              <blockquote class="text-center">
                <p class="text-[15px] lg:text-[27px] leading-relaxed mb-6" style={`font-family: var(--font-script); color: var(--color-body);`}>
                  &ldquo;{t.quote}&rdquo;
                </p>
                <footer>
                  <p class="text-[18px] font-bold" style="font-family: var(--font-narrow);">{t.name}</p>
                  <p class="text-sm text-gray-500">{t.role}</p>
                </footer>
              </blockquote>
            </div>
          ))}

          <!-- Navigation dots -->
          <div class="flex justify-center gap-3 mt-8">
            {testimonials.map((_, i) => (
              <button
                class:list={['testimonial-dot w-3 h-3 rounded-full transition-colors', i === 0 ? 'bg-primary' : 'bg-gray-300']}
                data-dot={i}
                aria-label={`Testimonial ${i + 1}`}
              />
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- BLOG POSTS -->
    <section class="py-16 lg:py-20 bg-white">
      <div class="container-site">
        <div class="text-center mb-12">
          <p class="eyebrow mb-3">Latest News</p>
          <h2 class="heading-section">Blog</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {blogPosts.map(post => (
            <div class="bg-white rounded-xl overflow-hidden shadow-[1px_1px_11px_1px_rgba(97,97,97,0.28)] hover:shadow-lg transition-shadow">
              <div class="h-48 overflow-hidden">
                <img src={post.image} alt={post.title} class="w-full h-full object-cover" />
              </div>
              <div class="p-6">
                <h3 class="heading-sub text-lg mb-2 leading-snug">{post.title}</h3>
                <p class="text-body text-sm text-gray-600">{post.excerpt}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- NEWSLETTER -->
    <section class="py-16 lg:py-20" style="background: linear-gradient(135deg, #042a49, #2196f3);">
      <div class="container-site text-center max-w-2xl mx-auto">
        <h2 class="text-white text-[25px] lg:text-[35px] mb-4" style="font-family: var(--font-heading);">Stay in the Loop</h2>
        <p class="text-white/80 text-lg mb-8">
          Stay updated with upcoming book events, author appearances, and media features.
        </p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input
            type="email"
            placeholder="Enter your email"
            required
            class="flex-1 px-4 py-3 rounded-lg text-body border-0 focus:outline-none focus:ring-2 focus:ring-accent"
          />
          <button
            type="submit"
            class="px-8 py-3 bg-accent text-primary-dark font-bold uppercase rounded-lg hover:bg-hero-heading transition-colors"
            style="font-family: var(--font-narrow); font-size: 18px;"
          >Sign Up</button>
        </form>
      </div>
    </section>

  </main>
</Layout>

<script>
  // Testimonial slider
  let current = 0;
  const slides = document.querySelectorAll('.testimonial-slide');
  const dots = document.querySelectorAll('.testimonial-dot');

  function showSlide(idx: number) {
    slides.forEach((s, i) => {
      (s as HTMLElement).classList.toggle('hidden', i !== idx);
    });
    dots.forEach((d, i) => {
      d.classList.toggle('bg-primary', i === idx);
      d.classList.toggle('bg-gray-300', i !== idx);
    });
    current = idx;
  }

  dots.forEach(d => {
    d.addEventListener('click', () => {
      showSlide(Number((d as HTMLElement).dataset.dot));
    });
  });

  // Auto-advance every 5 seconds
  setInterval(() => {
    showSlide((current + 1) % slides.length);
  }, 5000);
</script>
