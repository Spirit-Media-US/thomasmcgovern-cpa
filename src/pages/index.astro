    flex-shrink: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-image img {
    width: 100%;
    max-width: 380px;
    filter: drop-shadow(0 15px 40px rgba(0, 0, 0, 0.5));
  }
  .hero-text {
    width: 65%;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .hero-eyebrow {
    font-family: var(--font-body);
    color: #f5f5f5;
    font-size: 13px;
    font-weight: 300;
    margin: 0 0 12px 0;
    letter-spacing: 1px;
  }
  .hero-heading {
    font-family: var(--font-heading);
    color: #fff280;
    font-size: 45px;
    font-weight: 400;
    line-height: 1.1em;
    border-left: 3px solid #e0e0e0;
    padding-left: 20px;
    margin: 0 0 24px 0;
  }
  .hero-body {
    color: #f5f5f5;
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    margin: 0;
  }

  /* ===== FEATURED IN STRIP ===== */
