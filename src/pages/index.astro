---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { sanityClient, urlFor } from '../lib/sanity.ts';

const testimonials = await sanityClient.fetch(
  `*[_type == "testimonial"] | order(order asc) { quote, name, role }`
);

const blogPosts = await sanityClient.fetch(
  `*[_type == "blogPost"] | order(publishDate desc) [0...3] {
    title,
    "slug": "/blog/" + slug.current,
    "image": heroImage.asset->url + "?w=600&fm=webp&q=80"
  }`
);

// Mobile logo-row: displayed at ~93-134px wide — serve w=280 for retina sharpness
const carouselSlides = [
  { name: 'Barnes & Noble', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/629e606064be46ec62ed9b5d533dd5239287a89d-1536x864.png?w=280&fm=webp&q=75', w: 280, h: 158 },
  { name: 'Amazon', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/70d6a0a7825b64ac2411266758c020f8d8917a17-700x211.png?w=220&fm=webp&q=75', w: 220, h: 66 },
  { name: 'Bookshop', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/8965c4837800b4f95b98cf3bbb3a231e04c7fea0-1288x194.png?w=280&fm=webp&q=75', w: 280, h: 42 },
];

// Desktop: 5 logos (Barnes, Bookshop, Amazon, Barnes, Bookshop)
const desktopSlides = [
  { name: 'Barnes & Noble', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/629e606064be46ec62ed9b5d533dd5239287a89d-1536x864.png?w=500&fm=webp&q=80' },
  { name: 'Bookshop', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/8965c4837800b4f95b98cf3bbb3a231e04c7fea0-1288x194.png?w=500&fm=webp&q=80' },
  { name: 'Amazon', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/70d6a0a7825b64ac2411266758c020f8d8917a17-700x211.png?w=500&fm=webp&q=80' },
  { name: 'Barnes & Noble', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/629e606064be46ec62ed9b5d533dd5239287a89d-1536x864.png?w=500&fm=webp&q=80' },
  { name: 'Bookshop', url: 'https://cdn.sanity.io/images/fkqsnbt5/production/8965c4837800b4f95b98cf3bbb3a231e04c7fea0-1288x194.png?w=500&fm=webp&q=80' },
];
---

<Layout title="Thomas McGovern CPA — Road to the Final Hour">
  <Fragment slot="head">
    <!-- Preconnect Sanity CDN for earliest LCP fetch -->
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <!-- Preload LCP hero background (responsive — mobile gets smaller) -->
    <link
      rel="preload"
      as="image"
      href="https://cdn.sanity.io/images/fkqsnbt5/production/fd02252dc714934b8f179eae7c128d1d4e6c3c8a-1024x555.png?w=800&fm=webp&q=70"
      imagesrcset="https://cdn.sanity.io/images/fkqsnbt5/production/fd02252dc714934b8f179eae7c128d1d4e6c3c8a-1024x555.png?w=800&fm=webp&q=70 768w, https://cdn.sanity.io/images/fkqsnbt5/production/fd02252dc714934b8f179eae7c128d1d4e6c3c8a-1024x555.png?w=1600&fm=webp&q=75 1600w"
      imagesizes="100vw"
      fetchpriority="high"
    />
    <!-- Preload book cover (visible in hero but not the LCP element) -->
    <link
      rel="preload"
      as="image"
      href="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=360&fm=webp&q=80"
      imagesrcset="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=360&fm=webp&q=80 480w, https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=600&fm=webp&q=80 1024w"
      imagesizes="(max-width: 768px) 60vw, 380px"
    />
  </Fragment>
  <main>

    <!-- HERO -->
    <section class="hero-section">
      <div class="hero-inner container-site">
        <div class="hero-content">
          <!-- Left: book cover -->
          <div class="hero-image">
            <img
              src="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=600&fm=webp&q=80"
              srcset="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=360&fm=webp&q=80 480w, https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=600&fm=webp&q=80 1024w"
              sizes="(max-width: 768px) 60vw, 380px"
              alt="Road to the Final Hour book cover"
              width="500"
              height="500"
              loading="eager"
              decoding="async"
            />
          </div>
          <!-- Right: text -->
          <div class="hero-text">
            <h1 class="hero-heading">The Future of College Sports Hangs in the Balance</h1>
            <p class="hero-body">Discover how taxation, professionalization, and legislation could transform the game forever.</p>
            <a href="https://www.amazon.com/dp/B0DWDWWDY1" target="_blank" rel="noopener noreferrer" class="btn-primary" style="margin-top: 24px;">Buy the Book <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 448 512" fill="currentColor" style="display:inline;vertical-align:middle;margin-left:6px;"><path d="M257.2 162.7c-48.7 1.8-169.5 15.5-169.5 117.5 0 109.5 138.3 114 183.5 43.2 6.5 10.2 35.4 37.5 45.3 46.8l56.8-56S341 288.9 341 261.4V114.3C341 89 316.5 32 228.7 32 140.7 32 94 87 94 136.3l73.5 6.8c16.3-49.5 54.2-49.5 54.2-49.5 40.7-.1 35.5 29.8 35.5 69.1zm0 86.8c0 80-84.2 68-84.2 17.2 0-47.2 50.5-56.7 84.2-57.8v40.6zm136 163.5c-7.7 10-70 67-174.5 67S34.2 408.5 9.7 379c-6.8-7.7 1-11.3 5.5-8.3C88.5 415.2 203 488.5 387.7 401c7.5-3.7 13.3 2 5.5 12zm39.8-13.7c-9.8-7.5-32.4-14.3-51-7.7-5.7 1.8-5 6.3-1.3 7.7 10.2 3.3 33.4 10 46.3 7.5 12.7-2.3 13.7-3.7 6-7.5z"/></svg></a>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURED IN LOGOS -->
    <section class="featured-strip">
        <!-- Desktop: 5 logos -->
        <div class="logo-row-desktop">
          {desktopSlides.map(slide => (
            <div class="logo-item"><img src={slide.url} alt={slide.name} loading="lazy" decoding="async" class={slide.name === 'Amazon' ? 'logo-amazon' : slide.name === 'Barnes & Noble' ? 'logo-barnes' : ''} /></div>
          ))}
        </div>
        <!-- Mobile: 3 logos -->
        <div class="logo-row-mobile">
          {carouselSlides.map(slide => (
            <div class="logo-item"><img src={slide.url} alt={slide.name} loading="lazy" decoding="async" width={slide.w} height={slide.h} class={slide.name === 'Amazon' ? 'logo-amazon' : slide.name === 'Barnes & Noble' ? 'logo-barnes' : ''} /></div>
          ))}
        </div>
    </section>

    <!-- ABOUT ME -->
    <section id="about-me" class="about-section">
      <div class="container-site">
        <div class="about-row">
          <!-- Left: bio text (57%) -->
          <div class="about-left">
            <p class="eyebrow mb-2">WHAT I DO</p>
            <h2 class="heading-section mb-8">About <span>&nbsp;</span>Me</h2>
            <p class="text-body">
              Thomas A. McGovern is a Certified Public Accountant (CPA) and holds the Chartered Financial Analyst (CFA) designation. His extensive career includes twenty years as a Wall Street investment banker and equity research analyst. He has been involved in the higher education sector as a member of the board of directors of the University of Virginia's Manhattan alumni group, the Virginia Club of New York, and President of the Board of Governors of the St. Elmos national organization. Thomas McGovern earned a Master of Business Administration (MBA) from the Darden Graduate School of Business at the University of Virginia and an AB in Economics from Hamilton College where he graduated summa cum laude.
            </p>

            <hr class="section-divider" />

            <h3 class="heading-sub mb-5">Featured In:</h3>
            <div class="featured-carousel">
              <img src="https://cdn.sanity.io/images/fkqsnbt5/production/7c842983b4df241aa093074c7edc8353213baf1c-750x333.png?w=280&fm=webp&q=75" srcset="https://cdn.sanity.io/images/fkqsnbt5/production/7c842983b4df241aa093074c7edc8353213baf1c-750x333.png?w=280&fm=webp&q=75 280w, https://cdn.sanity.io/images/fkqsnbt5/production/7c842983b4df241aa093074c7edc8353213baf1c-750x333.png?w=400&fm=webp&q=80 400w" sizes="(max-width: 768px) 140px, 200px" alt="ESPN" class="carousel-logo" loading="lazy" decoding="async" width="200" height="89" />
              <img src="https://cdn.sanity.io/images/fkqsnbt5/production/38c6673397633951ff7e2ae5b0f2bc49d9754876-3840x2160.png?w=280&fm=webp&q=75" srcset="https://cdn.sanity.io/images/fkqsnbt5/production/38c6673397633951ff7e2ae5b0f2bc49d9754876-3840x2160.png?w=280&fm=webp&q=75 280w, https://cdn.sanity.io/images/fkqsnbt5/production/38c6673397633951ff7e2ae5b0f2bc49d9754876-3840x2160.png?w=400&fm=webp&q=80 400w" sizes="(max-width: 768px) 140px, 200px" alt="Wall Street Journal" class="carousel-logo" loading="lazy" decoding="async" width="200" height="113" />
              <img src="https://cdn.sanity.io/images/fkqsnbt5/production/820cf4a6fc991d2b9b92fcd1d1a436192854fe01-4736x886.png?w=280&fm=webp&q=75" srcset="https://cdn.sanity.io/images/fkqsnbt5/production/820cf4a6fc991d2b9b92fcd1d1a436192854fe01-4736x886.png?w=280&fm=webp&q=75 280w, https://cdn.sanity.io/images/fkqsnbt5/production/820cf4a6fc991d2b9b92fcd1d1a436192854fe01-4736x886.png?w=400&fm=webp&q=80 400w" sizes="(max-width: 768px) 140px, 200px" alt="USA Today" class="carousel-logo" loading="lazy" decoding="async" width="200" height="37" />
            </div>
          </div>

          <!-- Right: headshot (40%) -->
          <div class="about-right">
            <div class="about-photo-wrapper">
              <img
                src="https://cdn.sanity.io/images/fkqsnbt5/production/fddd87a4ca10681a164c04643a9aa0deecbfe532-1200x1800.jpg?w=600&fm=webp&q=80"
                alt="Thomas A. McGovern"
                class="about-photo"
                loading="lazy"
                decoding="async"
                width="600"
                height="900"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="stats-section">
      <div class="container-site">
        <div class="stats-row">
          <div class="stat-item">
            <div class="stat-number"><span class="stat-count" data-target="25">25</span><span class="stat-suffix">+</span></div>
            <p class="stat-label">Years of Experienced</p>
          </div>
          <div class="stat-item">
            <div class="stat-number"><span class="stat-count" data-target="3">3</span><span class="stat-suffix">+</span></div>
            <p class="stat-label">Books Written</p>
          </div>
          <div class="stat-item">
            <div class="stat-number"><span class="stat-count" data-target="3">3</span><span class="stat-suffix">K +</span></div>
            <p class="stat-label">Happy Readers</p>
          </div>
          <div class="stat-item">
            <div class="stat-number"><span class="stat-count" data-target="12">12</span><span class="stat-suffix">+</span></div>
            <p class="stat-label">Awards Recognitions</p>
          </div>
        </div>
      </div>
    </section>

    <!-- BOOK SECTION -->
    <section class="book-section">
      <div class="container-site">
        <p class="eyebrow mb-2" style="text-align: center;">SHOWCASE</p>
        <h2 class="heading-section" style="text-align: center;">About the <span>&nbsp;</span>Book</h2>

        <!-- Overview: image left + text right -->
        <div class="book-overview card-shadow-light">
          <div class="book-overview-image" style="background-image: url('https://cdn.sanity.io/images/fkqsnbt5/production/83fb29edffe6af52b5b8c5ef2cd51d56f4c72ef9-1024x510.png?w=700&fm=webp&q=75');"></div>
          <div class="book-overview-text">
            <h3 class="heading-sub-sm mb-5">Overview</h3>
            <p class="text-body">
              Discover Road to the Final Hour, an in-depth exploration of the forces threatening to reshape college athletics. From taxation to professionalization, this book unpacks the complexities of the current landscape and provides a compelling case for preserving the spirit of college sports.
            </p>
          </div>
        </div>

        <!-- Quote + Chapters Preview in one block -->
        <div class="quote-chapters-block">
          <div class="quote-inner">
            <p class="quote-text">
              &ldquo;College sports are at a crossroads, and how we address these challenges will define the future of intercollegiate athletics for generations to come.&rdquo;
            </p>
            <p class="quote-attribution">- Thomas A. McGovern</p>
          </div>

          <!-- 3 columns below quote -->
          <div class="chapters-3col">
          <!-- Left: Chapters Preview text + button -->
          <div class="chapters-left">
            <h3 class="heading-sub mb-5">Chapters Preview</h3>
            <p class="text-body">Discover how taxation, professionalization, and legislation could transform the game forever.</p>
            <a href="https://www.amazon.com/dp/B0DWDWWDY1" target="_blank" rel="noopener noreferrer" class="btn-primary mt-5 inline-block">Buy the Book <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 448 512" fill="currentColor" style="display:inline;vertical-align:middle;margin-left:6px;"><path d="M257.2 162.7c-48.7 1.8-169.5 15.5-169.5 117.5 0 109.5 138.3 114 183.5 43.2 6.5 10.2 35.4 37.5 45.3 46.8l56.8-56S341 288.9 341 261.4V114.3C341 89 316.5 32 228.7 32 140.7 32 94 87 94 136.3l73.5 6.8c16.3-49.5 54.2-49.5 54.2-49.5 40.7-.1 35.5 29.8 35.5 69.1zm0 86.8c0 80-84.2 68-84.2 17.2 0-47.2 50.5-56.7 84.2-57.8v40.6zm136 163.5c-7.7 10-70 67-174.5 67S34.2 408.5 9.7 379c-6.8-7.7 1-11.3 5.5-8.3C88.5 415.2 203 488.5 387.7 401c7.5-3.7 13.3 2 5.5 12zm39.8-13.7c-9.8-7.5-32.4-14.3-51-7.7-5.7 1.8-5 6.3-1.3 7.7 10.2 3.3 33.4 10 46.3 7.5 12.7-2.3 13.7-3.7 6-7.5z"/></svg></a>
          </div>
          <!-- Center: Book cover -->
          <div class="chapters-center">
            <img
              src="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=420&fm=webp&q=75"
              srcset="https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=420&fm=webp&q=75 480w, https://cdn.sanity.io/images/fkqsnbt5/production/ac2af2b09f1199c080cfd8dbf27ececfaf3a2d60-1024x1024.png?w=500&fm=webp&q=80 1024w"
              sizes="(max-width: 768px) 70vw, 30vw"
              alt="Road to the Final Hour book cover"
              loading="lazy"
              decoding="async"
              width="500"
              height="500"
            />
          </div>
          <!-- Right: 3 chapter cards stacked -->
          <div class="chapters-right">
            <div class="chapter-card card-shadow">
              <div class="chapter-card-inner">
                <span class="chapter-icon">&#10004;</span>
                <div>
                  <h4 class="chapter-card-title"><em>The Labor Issue</em></h4>
                  <p class="chapter-card-text">Examines the push to classify college athletes as employees and its implications.</p>
                </div>
              </div>
            </div>
            <div class="chapter-card card-shadow">
              <div class="chapter-card-inner">
                <span class="chapter-icon">&#10004;</span>
                <div>
                  <h4 class="chapter-card-title"><em>Effects of Taxation</em></h4>
                  <p class="chapter-card-text">Unpacks how UBTI and loss of tax-exempt status could cripple the industry.</p>
                </div>
              </div>
            </div>
            <div class="chapter-card card-shadow">
              <div class="chapter-card-inner">
                <span class="chapter-icon">&#10004;</span>
                <div>
                  <h4 class="chapter-card-title"><em>The Bigger Issue</em></h4>
                  <p class="chapter-card-text">Explores the ideological battle over the value of college sports in society.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        </div>
      </div>
    </section>

    <!-- FOOTBALL BANNER -->
    <section class="football-banner"></section>

    <!-- THE ISSUES -->
    <section class="issues-section">
      <div class="container-site relative z-10">
        <p class="eyebrow mb-2">MORE INFO ABOUT THE BOOK</p>
        <h2 class="heading-section" style="margin-bottom: 40px;">The Issues</h2>

        <!-- Infographic -->
        <div class="mt-8 mb-8">
          <img
            src="https://cdn.sanity.io/images/fkqsnbt5/production/be37419005c1c164a021dca8ff787c180c7f8f04-1200x456.png?w=1000&fm=webp&q=80"
            alt="Before Infographic"
            class="w-full"
            loading="lazy"
            decoding="async"
            width="1000"
            height="380"
          />
        </div>

        <!-- Tax-exempt status -->
        <h3 class="heading-sub">What Happens When College Athletics Lose Tax-Exempt Status?</h3>
        <p class="text-body mt-5">
          The imposition of Unrelated Business Income Tax (UBTI) could drastically alter the financial foundation of college sports. A 21% federal corporate tax, combined with state taxes, would reduce funds available for non revenue sports and student-athlete scholarships.
        </p>

        <hr class="section-divider-thin" />

        <!-- Cultural significance: image left + text right -->
        <div class="issues-row card-shadow-light">
          <div class="issues-row-image" style="background-image: url('https://cdn.sanity.io/images/fkqsnbt5/production/f0837f92d1e3259acfb59d8fef4a20d945ba4dfb-660x440.webp?w=700&fm=webp&q=75');"></div>
          <div class="issues-row-text">
            <h3 class="heading-sub" style="width: 75%;">Cultural Significance of College Athletics</h3>
            <p class="text-body mt-5">
              &ldquo;More Than a Game&rdquo; College athletics produce Olympians, foster teamwork, and teach life skills. Cutting programs would not only hurt athletes but also the broader educational mission of U.S. universities.
            </p>
          </div>
        </div>

        <hr class="section-divider-thin" />

        <!-- Scenario cards -->
        <h3 class="heading-sub-sm mb-5">Two Scenarios for Professionalization</h3>

        <div class="scenario-row">
          <div class="scenario-card">
            <p class="heading-gray">Scenario 1</p>
            <p class="text-body mt-2.5">Professionalizing only revenue sports like football and basketball.</p>
          </div>
          <div class="scenario-card">
            <p class="heading-gray">Scenario 2</p>
            <p class="text-body mt-2.5">Professionalizing all intercollegiate sports, with catastrophic financial consequences.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="testimonials-section">
      <div class="container-site" style="position: relative; z-index: 1;">
        <div>
          <p class="eyebrow mb-2">WHAT OTHER SAYS</p>
          <h2 class="heading-section mb-10">Testimonials</h2>
        </div>

        <!-- Map background wrapper -->
        <div class="testimonials-map-wrapper">
          <div class="testimonials-slider-wrapper">
            <!-- Arrow left -->
            <button class="testi-arrow testi-prev" id="testi-prev" aria-label="Previous">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            </button>

            <!-- Slides — 1 testimonial per slide -->
            <div class="testi-viewport">
              <div class="testi-track" id="testi-track">
                {testimonials.map((t: any) => (
                  <div class="testi-slide">
                    <div class="testi-card">
                      <p class="testi-quote">&ldquo;{t.quote}&rdquo;</p>
                      <p class="testi-name">{t.name}</p>
                      <p class="testi-title">{t.role}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Arrow right -->
            <button class="testi-arrow testi-next" id="testi-next" aria-label="Next">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>

          <!-- Dots -->
          <div class="testi-dots" id="testi-dots"></div>
        </div>
      </div>
    </section>

    <!-- BLOG POSTS -->
    <section class="blog-section">
      <div class="container-site">
        <div class="text-center">
          <p class="eyebrow mb-2">ARCHIVES</p>
          <h2 class="heading-section mb-10">Blog & News</h2>
        </div>

        <div class="blog-grid">
          {blogPosts.map(post => (
            <div class="blog-card">
              <div class="blog-card-image" style={`background-image: url('${post.image}');`}></div>
              <div class="p-5">
                <h3 class="blog-card-title">{post.title}</h3>
                <a href={post.slug} class="btn-primary blog-card-btn">Read more ...</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- NEWSLETTER -->
    <section class="newsletter-section">
      <div class="newsletter-overlay"></div>
      <div class="container-site relative z-10">
        <div class="newsletter-row">
          <div>
            <p class="newsletter-heading">Stay updated with upcoming book events, author appearances, and media features.</p>
          </div>
          <div class="newsletter-form-wrapper">
            <form action="/api/newsletter" method="POST" class="newsletter-form">
              <input
                type="email"
                placeholder="Your Email"
                required
                class="newsletter-input"
              />
              <button
                type="submit"
                class="newsletter-btn"
              >Sign Up</button>
            </form>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  // Testimonial slider — responsive: 1 per view on mobile, 2 on desktop
  (function() {
    const track = document.getElementById('testi-track');
    const prevBtn = document.getElementById('testi-prev');
    const nextBtn = document.getElementById('testi-next');
    const dotsContainer = document.getElementById('testi-dots');
    if (!track || !dotsContainer) return;

    const slides = track.querySelectorAll('.testi-slide');
    const totalSlides = slides.length;
    let pos = 0;
    let perView = window.innerWidth <= 768 ? 1 : 2;

    function getPageCount() { return Math.ceil(totalSlides / perView); }

    function buildDots() {
      const pages = getPageCount();
      dotsContainer.innerHTML = '';
      dotsContainer.style.cssText = 'display:flex;justify-content:center;gap:10px;margin-top:20px;position:relative;z-index:2;';
      for (let i = 0; i < pages; i++) {
        const btn = document.createElement('button');
        btn.className = 'testi-dot';
        btn.style.cssText = 'width:48px;height:48px;border-radius:50%;border:none;cursor:pointer;padding:12px;transition:opacity 0.3s;background:transparent;display:flex;align-items:center;justify-content:center;';
        const inner = document.createElement('span');
        inner.style.cssText = 'display:block;width:100%;height:100%;border-radius:50%;background:' + (i === 0 ? '#616161' : '#d4d4d4') + ';transition:background 0.3s;';
        btn.appendChild(inner);
        btn.setAttribute('aria-label', `Go to slide ${i + 1}`);
        btn.dataset.slide = String(i);
        btn.addEventListener('click', () => slideTo(i));
        dotsContainer.appendChild(btn);
      }
    }

    function updateLayout() {
      const slideWidth = 100 / perView;
      slides.forEach(s => { (s as HTMLElement).style.flex = `0 0 ${slideWidth}%`; });
    }

    function slideTo(p: number) {
      const pages = getPageCount();
      pos = ((p % pages) + pages) % pages;
      const offset = pos * (100 / perView);
      track.style.transition = 'transform 0.5s ease';
      track.style.transform = `translateX(-${offset}%)`;
      dotsContainer.querySelectorAll('.testi-dot > span').forEach((d, i) => { (d as HTMLElement).style.background = i === pos ? '#616161' : '#d4d4d4'; });
    }

    function init() {
      perView = window.innerWidth <= 768 ? 1 : 2;
      pos = 0;
      updateLayout();
      buildDots();
      slideTo(0);
    }

    init();
    window.addEventListener('resize', init);

    prevBtn?.addEventListener('click', () => slideTo(pos - 1));
    nextBtn?.addEventListener('click', () => slideTo(pos + 1));

    let interval = setInterval(() => slideTo(pos + 1), 5000);
    track.parentElement?.parentElement?.addEventListener('mouseenter', () => clearInterval(interval));
    track.parentElement?.parentElement?.addEventListener('mouseleave', () => {
      interval = setInterval(() => slideTo(pos + 1), 5000);
    });
  })();

  // Counter animation
  function animateCounters() {
    const counters = document.querySelectorAll('.stat-count');
    counters.forEach(counter => {
      const el = counter as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      const duration = 1000;
      const startTime = performance.now();

      function update(currentTime: number) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const value = Math.floor(progress * target);
        el.textContent = String(value || 1);
        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          el.textContent = String(target);
        }
      }
      requestAnimationFrame(update);
    });
  }

  // Trigger counters when stats section is visible
  const statsSection = document.querySelector('.stats-section');
  if (statsSection) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounters();
          observer.disconnect();
        }
      });
    }, { threshold: 0.3 });
    observer.observe(statsSection);
  }
</script>

