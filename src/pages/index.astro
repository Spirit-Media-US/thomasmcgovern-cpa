    background-size: cover;
    background-blend-mode: multiply;
    padding-top: 220px;
    padding-bottom: 80px;
  }
  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(#03213a, rgba(1, 83, 121, 0.79));
